{
  "name": "@aspectly/transports",
  "version": "2.0.15",
  "description": "Transport layer for Aspectly bridge - platform detection and message passing",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./cefsharp": {
      "import": {
        "types": "./dist/cefsharp.d.mts",
        "default": "./dist/cefsharp.mjs"
      },
      "require": {
        "types": "./dist/cefsharp.d.ts",
        "default": "./dist/cefsharp.js"
      }
    },
    "./webkit": {
      "import": {
        "types": "./dist/webkit.d.mts",
        "default": "./dist/webkit.mjs"
      },
      "require": {
        "types": "./dist/webkit.d.ts",
        "default": "./dist/webkit.js"
      }
    },
    "./android": {
      "import": {
        "types": "./dist/android.d.mts",
        "default": "./dist/android.mjs"
      },
      "require": {
        "types": "./dist/android.d.ts",
        "default": "./dist/android.js"
      }
    },
    "./flutter": {
      "import": {
        "types": "./dist/flutter.d.mts",
        "default": "./dist/flutter.mjs"
      },
      "require": {
        "types": "./dist/flutter.d.ts",
        "default": "./dist/flutter.js"
      }
    },
    "./react-native": {
      "import": {
        "types": "./dist/react-native.d.mts",
        "default": "./dist/react-native.mjs"
      },
      "require": {
        "types": "./dist/react-native.d.ts",
        "default": "./dist/react-native.js"
      }
    },
    "./iframe": {
      "import": {
        "types": "./dist/iframe.d.mts",
        "default": "./dist/iframe.mjs"
      },
      "require": {
        "types": "./dist/iframe.d.ts",
        "default": "./dist/iframe.js"
      }
    },
    "./window": {
      "import": {
        "types": "./dist/window.d.mts",
        "default": "./dist/window.mjs"
      },
      "require": {
        "types": "./dist/window.d.ts",
        "default": "./dist/window.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "keywords": [
    "aspectly",
    "bridge",
    "transport",
    "cefsharp",
    "webkit",
    "wkwebview",
    "ios",
    "macos",
    "android",
    "flutter",
    "webview",
    "iframe",
    "postmessage"
  ],
  "author": "Zhan Isaakian <jeanisahkyan@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JeanIsahakyan/aspectly",
    "directory": "packages/transports"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "rimraf": "^5.0.5"
  }
}
